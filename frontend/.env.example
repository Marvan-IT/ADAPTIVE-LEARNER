# Frontend environment variables — copy this file to .env and fill in real values.
# Never commit .env to version control.
# All variables must be prefixed with VITE_ to be exposed to the browser bundle.

# -------------------------------------------------------------------
# API
# -------------------------------------------------------------------
# Base URL of the backend FastAPI server.
VITE_API_BASE_URL=http://localhost:8000

# -------------------------------------------------------------------
# Security
# -------------------------------------------------------------------
# Must match the API_SECRET_KEY set in backend/.env.
VITE_API_SECRET_KEY=change-me-same-as-backend-API_SECRET_KEY

# -------------------------------------------------------------------
# Analytics (optional)
# -------------------------------------------------------------------
# PostHog project API key. Leave blank to disable analytics.
VITE_POSTHOG_KEY=phc_your-posthog-project-key-here
