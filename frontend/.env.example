# ADA Frontend Environment Variables
# Copy this file to .env and fill in your values

VITE_API_BASE_URL=http://localhost:8889   # Backend URL (must match backend port)
VITE_POSTHOG_KEY=                         # Optional: PostHog analytics key
VITE_API_SECRET_KEY=                      # Legacy: only needed if JWT auth is not yet enabled
                                          # With JWT auth, authentication is handled via Bearer tokens
