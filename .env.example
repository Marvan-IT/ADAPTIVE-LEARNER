# ── Shared Docker Compose secrets ────────────────────────────────────────────
# Copy this file to .env and fill in real values before running docker compose.
#
# Required variables are marked [REQUIRED]. All others are optional.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# [REQUIRED] Password for the postgres user (used by db and backend services)
POSTGRES_PASSWORD=

# ── Domain & URLs ────────────────────────────────────────────────────────────
# [REQUIRED] Your domain name (used by deploy.sh for SSL and nginx)
# Example: ada.yourdomain.com
DOMAIN=

# [REQUIRED] Frontend origin for CORS (must include https://)
FRONTEND_URL=https://YOUR_DOMAIN

# [REQUIRED] Base URL for serving extracted textbook images
IMAGE_BASE_URL=https://YOUR_DOMAIN/images

# ── Frontend Build Args ──────────────────────────────────────────────────────
# [REQUIRED] Must match API_SECRET_KEY in backend/.env — Vite bakes this into the JS bundle
VITE_API_SECRET_KEY=

# Optional: PostHog analytics key
VITE_POSTHOG_KEY=
