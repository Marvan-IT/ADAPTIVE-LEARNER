# ── Shared Docker Compose secrets ────────────────────────────────────────────
# Copy this file to .env and fill in real values.

# PostgreSQL password (used by both db and backend services)
POSTGRES_PASSWORD=

# Must match API_SECRET_KEY in backend/.env — Vite bakes this into the frontend build
VITE_API_SECRET_KEY=

# Your domain name (used for CORS and image URLs)
# Example: ada.yourdomain.com
DOMAIN=

# Set these after DOMAIN is known:
FRONTEND_URL=https://YOUR_DOMAIN
IMAGE_BASE_URL=https://YOUR_DOMAIN/images

# Optional: PostHog analytics
VITE_POSTHOG_KEY=
