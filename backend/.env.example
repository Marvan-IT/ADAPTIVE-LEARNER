# Backend environment variables — copy this file to .env and fill in real values.
# Never commit .env to version control.

# -------------------------------------------------------------------
# OpenAI
# -------------------------------------------------------------------
# Your OpenAI API key (required).
OPENAI_API_KEY=sk-...your-openai-api-key-here...

# Optional: override the default OpenAI API base URL (e.g. for a proxy or Azure endpoint).
# Leave blank to use the official OpenAI endpoint.
OPENAI_BASE_URL=https://api.openai.com/v1

# Model identifiers — change only if you have access to a different model tier.
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_MINI=gpt-4o-mini

# -------------------------------------------------------------------
# Database
# -------------------------------------------------------------------
# PostgreSQL connection string (asyncpg driver required).
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/AdaptiveLearner

# -------------------------------------------------------------------
# Mathpix (PDF math OCR — required only for the extraction pipeline)
# -------------------------------------------------------------------
MATHPIX_APP_ID=your-mathpix-app-id
MATHPIX_APP_KEY=your-mathpix-app-key

# -------------------------------------------------------------------
# Security
# -------------------------------------------------------------------
# Secret key used for request signing / rate-limit tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-me-to-a-random-32-char-hex-string

# URL of the frontend (used for CORS allow-origins).
FRONTEND_URL=http://localhost:5173
