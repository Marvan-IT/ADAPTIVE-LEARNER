# ADA Backend Environment Variables
# Copy this file to .env and fill in your values

OPENAI_API_KEY=                    # Required: your OpenAI API key
OPENAI_BASE_URL=                   # Optional: custom base URL (leave blank for OpenAI default)
OPENAI_MODEL=gpt-4o                # LLM for card generation and Socratic sessions
OPENAI_MODEL_MINI=gpt-4o-mini      # LLM for lightweight tasks (translation, MCQ regen)

MATHPIX_APP_ID=                    # Required for PDF math OCR (can leave blank if not using pipeline)
MATHPIX_APP_KEY=                   # Required for PDF math OCR (can leave blank if not using pipeline)

DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/AdaptiveLearner
                                   # Required: PostgreSQL connection string

API_SECRET_KEY=                    # Required: random 32-char hex string for API auth
                                   # Generate with: python -c "import secrets; print(secrets.token_hex(32))"

FRONTEND_URL=http://localhost:5173  # CORS allowed origins (comma-separated for multiple)
REDIS_URL=                         # Optional: Redis URL for distributed rate limiting
ENVIRONMENT=development    # Change to "production" in production deployments

# ── Authentication ──────────────────────────────────────────────────
JWT_SECRET_KEY=                    # Required: random 64-char hex for JWT signing
                                   # Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# ── Email (Gmail SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com           # SMTP server (leave blank in dev to log OTPs to console)
SMTP_PORT=587
SMTP_USER=                         # Gmail address
SMTP_PASSWORD=                     # Gmail App Password (not your regular password)
SMTP_FROM=                         # Same as SMTP_USER

# Internal service URL for watcher → backend communication
API_BASE_URL=http://backend:8889     # Internal URL for watcher to call load-book endpoint
                                     # Use http://localhost:8889 for local dev (outside Docker)
# Production S3 settings (only needed when IMAGE_STORAGE=s3):
# AWS_S3_BUCKET=ada-images-prod
# AWS_REGION=us-east-1
