\section*{EXAMPLE 2.11}

Solve: $\frac{1}{2}(y-5)=\frac{1}{4}(y-1)$.

\section*{Solution}

\begin{tabular}{|l|l|}
\hline & $\frac{1}{2}(y-5)=\frac{1}{4}(y-1)$ \\
\hline Distribute. & $\frac{1}{2} \cdot y-\frac{1}{2} \cdot 5=\frac{1}{4} \cdot y-\frac{1}{4} \cdot 1$ \\
\hline Simplify. & $\frac{1}{2} y-\frac{5}{2}=\frac{1}{4} y-\frac{1}{4}$ \\
\hline Multiply by the LCD, four. & $4\left(\frac{1}{2} y-\frac{5}{2}\right)=4\left(\frac{1}{4} y-\frac{1}{4}\right)$ \\
\hline Distribute. & $4 \cdot \frac{1}{2} y-4 \cdot \frac{5}{2}=4 \cdot \frac{1}{4} y-4 \cdot \frac{1}{4}$ \\
\hline Simplify. & $2 y-10=y-1$ \\
\hline
\end{tabular}

\begin{tabular}{|l|l|l|}
\hline Collect the variables to the left. & & $2 y-y-10=y-y-1$ \\
\hline Simplify. & & $y-10=-1$ \\
\hline Collect the constants to the right. & & $y-10+10=-1+10$ \\
\hline Simplify. & & $y=9$ \\
\hline \multicolumn{3}{|l|}{An alternate way to solve this equation is to clear the fractions without distributing first. If you multiply the factors correctly, this method will be easier.} \\
\hline & & \\
\hline Multiply by the LCD, 4. & & $4 \cdot \frac{1}{2}(y-5)=4 \cdot \frac{1}{4}(y-1)$ \\
\hline Multiply four times the fractions. & & $2(y-5)=1(y-1)$ \\
\hline Distribute. & & $2 y-10=y-1$ \\
\hline Collect the variables to the left. & & $2 y-y-10=y-y-1$ \\
\hline Simplify. & & $y-10=-1$ \\
\hline Collect the constants to the right. & & $y-10+10=-1+10$ \\
\hline Simplify. & & $y=9$ \\
\hline Check: & $\frac{1}{2}(y-5)=\frac{1}{4}(y-1)$ & \\
\hline Let $y=9$. & $\frac{1}{2}(9-5) \stackrel{?}{=} \frac{1}{4}(9-1)$ & \\
\hline Finish the check on your own. & & \\
\hline
\end{tabular}
